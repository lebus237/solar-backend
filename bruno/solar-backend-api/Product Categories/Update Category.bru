meta {
  name: Update Category
  type: http
  seq: 4
}

put {
  url: {{base_url}}/api/product-category/{{category_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "designation": "Updated Category Name",
    "type": "CATEGORY"
  }
}

tests {
  test("should return 204 on success", function() {
    expect(res.status).toBe(204);
  });
}
