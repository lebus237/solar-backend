meta {
  name: Create Store
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/store
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "designation": "My Store",
    "domainUrl": "https://mystore.com",
    "description": "My store description"
  }
}

tests {
  test("should return 201 on success", function() {
    expect(res.status).toBe(201);
  });
}
