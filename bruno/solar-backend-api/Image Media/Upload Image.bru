meta {
  name: Upload Image
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/image-media
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:formdata {
  image@./path/to/image.jpg
  {
    "title": "Sample Image",
    "alt": "Sample alt text"
  }
}

tests {
  test("should return 201 on success", function() {
    expect(res.status).toBe(201);
  });

  test("should return image data", function() {
    const body = res.body;
    expect(body).toBeTruthy();
  });
}
